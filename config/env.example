OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=...
# Gemini 用の最終フォールバック。上記が欠損している場合のみ参照される。
# GOOGLE_API_KEY=...
# Legacy compatibility:
# GEMINI_API_KEY=...
# 将来のマルチプロバイダー切り替え用プレースホルダー（現状未使用）
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-5-main
# デフォルトで利用する推論チェーン（`single` / `reflect`）。未設定時は `single`
DEFAULT_CHAIN=single
CHAINLIT_AUTH_SECRET=change-me
PORT=8787
# DEBUG=1  # 詳細ログが必要なときのみ一時的に有効化

# =============================================================================
# OAuth Configuration (M1.5)
# =============================================================================
# Configure at least one OAuth provider to enable UI authentication.
# See: https://docs.chainlit.io/authentication/oauth

# GitHub OAuth
# OAUTH_GITHUB_CLIENT_ID=your-github-client-id
# OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
# OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
# OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure AD OAuth
# OAUTH_AZURE_AD_CLIENT_ID=your-azure-client-id
# OAUTH_AZURE_AD_CLIENT_SECRET=your-azure-client-secret
# OAUTH_AZURE_AD_TENANT_ID=your-tenant-id
# OAUTH_AZURE_AD_ENABLE_SINGLE_TENANT=false

# Generic OAuth Provider
# OAUTH_GENERIC_CLIENT_ID=your-client-id
# OAUTH_GENERIC_CLIENT_SECRET=your-client-secret
# OAUTH_GENERIC_AUTH_URL=https://provider.example.com/oauth/authorize
# OAUTH_GENERIC_TOKEN_URL=https://provider.example.com/oauth/token
# OAUTH_GENERIC_USER_INFO_URL=https://provider.example.com/oauth/userinfo
# OAUTH_GENERIC_SCOPES=openid profile email
# OAUTH_GENERIC_NAME=custom-provider
# OAUTH_GENERIC_USER_IDENTIFIER=email

# =============================================================================
# Memory Persistence Configuration (M2.5)
# =============================================================================
# Storage backend: 'memory' (default, for development) or 'postgres'
MEMORY_STORAGE_BACKEND=memory

# PostgreSQL configuration (when MEMORY_STORAGE_BACKEND=postgres)
# MEMORY_POSTGRES_HOST=localhost
# MEMORY_POSTGRES_PORT=5432
# MEMORY_POSTGRES_DATABASE=katamari
# MEMORY_POSTGRES_USER=katamari
# MEMORY_POSTGRES_PASSWORD=your-password

# Embedding storage configuration
# MEMORY_EMBEDDING_ENABLED=false
# MEMORY_EMBEDDING_MODEL=text-embedding-3-small

# Retention settings
# MEMORY_CONVERSATION_TTL_DAYS=30
# MEMORY_EMBEDDING_TTL_DAYS=90
